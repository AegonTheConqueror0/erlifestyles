rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isDistributor() { return isSignedIn() && exists(/databases/$(database)/documents/distributors/$(request.auth.uid)); }

    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerEmail', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.customerEmail is string && data.customerEmail.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    function isValidDistributor(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'status']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.email is string &&
             data.status in ['active', 'inactive'];
    }

    // Collection Rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or specialized service
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read: if isAdmin() || (isDistributor() && existing().distributorId == request.auth.uid);
      allow update: if (isAdmin() || (isDistributor() && existing().distributorId == request.auth.uid)) &&
                   isValidOrder(incoming()) &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'distributorId']) &&
                   incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /distributors/{distId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == distId);
      allow create: if isAdmin() && isValidDistributor(incoming());
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid == distId)) &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status']) &&
                   (incoming().status == existing().status || isAdmin()); // Only admin can change status
      allow delete: if isAdmin();
    }
  }
}
