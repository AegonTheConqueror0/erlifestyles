rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == "admin@erwellness.com" ||
        request.auth.token.email == "edgardo.rojas@hcdc.edu.ph"
      ); 
    }
    function isDistributor() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/distributors/$(request.auth.uid)) || 
        request.auth.token.email == "partner@erwellness.com"
      ); 
    }

    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerEmail', 'customerName', 'customerAddress', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.customerEmail is string && data.customerEmail.size() > 0 &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerAddress is string && data.customerAddress.size() > 0 &&
             (!data.keys().contains('customerPhone') || data.customerPhone is string) &&
             (!data.keys().contains('coordinates') || (data.coordinates is map && data.coordinates.lat is number && data.coordinates.lng is number)) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidDistributor(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'status']) &&
             (data.uid == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string &&
             data.status in ['active', 'inactive'];
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'text', 'rating', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.text is string && data.text.size() > 0 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt is timestamp;
    }

    // Collection Rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow read: if isAdmin() || isDistributor();
      allow update: if (isAdmin() || isDistributor()) &&
                   isValidOrder(incoming()) &&
                   incoming().createdAt == existing().createdAt &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'distributorId']) &&
                   (incoming().updatedAt == request.time || isAdmin()); 
      allow delete: if isAdmin() || isDistributor();
    }

    match /distributors/{distId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == distId);
      allow create: if isAdmin() && isValidDistributor(incoming());
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid == distId)) &&
                   incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'updatedAt']) &&
                   (incoming().status == existing().status || isAdmin()); 
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTestimonial(incoming());
      allow delete: if isAdmin();
    }
  }
}
